# Copy to .env and fill in values

# Database — SQLite for dev, swap to PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./data/ct_records.db
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/ct_records

# App
DEBUG=false
SECRET_KEY=change-me-please-use-a-long-random-string

# CORS (comma-separated origins — not used in Docker since nginx handles it)
ALLOWED_ORIGINS=["http://localhost", "http://localhost:3000"]

# Playwright
PLAYWRIGHT_HEADLESS=true

# Scheduler timezone
SCHEDULER_TIMEZONE=America/New_York
